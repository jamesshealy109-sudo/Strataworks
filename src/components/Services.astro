---
const services = [
  {
    title: 'Enterprise Networking',
    text: 'Routing, switching, Wi-Fi, firewalls, VPNs, SD-WAN guidance, troubleshooting, and documentation.'
  },
  {
    title: 'Infrastructure & Hosting',
    text: 'Servers, virtualization, storage, backups, monitoring, business continuity, and practical cloud strategy.'
  },
  {
    title: 'Voice & Communications',
    text: 'PBX design, IVRs, SIP troubleshooting, call flows, hosted voice, and customer communication improvements.'
  },
  {
    title: 'AI & Automation',
    text: 'Webhooks, AI workflows, reporting, customer reminders, intake flows, and repetitive-task cleanup.'
  },
  {
    title: 'Web & Digital Systems',
    text: 'Fast websites, landing pages, contact forms, DNS, hosting, SEO basics, and integrations that support operations.'
  },
  {
    title: 'IT Roadmaps',
    text: 'Clear recommendations, upgrade planning, documentation, vendor review, and project execution without fluff.'
  }
];
---

<section class="section" id="services">
  <div class="section-head">
    <p class="eyebrow">What StrataWorks does</p>
    <h2>Practical support for real business problems.</h2>
    <p>
      No overbuilt stacks. No mystery invoices. Just smart technical work that is scoped clearly,
      implemented cleanly, and documented so your business is better after the project is done.
    </p>
  </div>

  <div class="service-grid">
    {services.map((service, index) => (
      <article class="service-card" style={`--i:${index}`}>
        <div class="card-number">0{index + 1}</div>
        <h3>{service.title}</h3>
        <p>{service.text}</p>
      </article>
    ))}
  </div>
</section>