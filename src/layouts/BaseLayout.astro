---
import '../styles/global.css';

const {
  title = 'StrataWorks Tech | IT Consulting, Automation & Infrastructure',
  description = 'StrataWorks Tech provides practical IT consulting, network engineering, infrastructure, VoIP, automation, and web solutions for small businesses.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#06101f" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://strataworks.tech/" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://strataworks.tech/" />
    <meta property="og:image" content="/assets/strataworks-logo.png" />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>